{
    "name": "quadprog",
    "description": "Module for solving quadratic programming problems",
    "version": "2.0.0",
    "type": "module",
    "exports": {
        ".": {
            "import": "./index.js",
            "require": "./index.cjs"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/albertosantini/quadprog.git"
    },
    "keywords": [
        "quadprog",
        "solving",
        "quadratic"
    ],
    "author": "Alberto Santini",
    "license": "MIT",
    "engines": {
        "node": ">=24.x"
    },
    "scripts": {
        "test": "npm run lint && node --test --experimental-test-coverage --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=100 --test-reporter=spec test/solution-test.js && npm run benchmark",
        "lint": "eslint .",
        "lint-ts": "npx --yes -p @typescript/native-preview tsgo -p jsconfig.json --noEmit",
        "validate": "npm run lint && npm run lint-ts && npm run test",
        "benchmark": "node test/bench.js",
        "benchmark:profile": "node --cpu-prof test/bench.js --synthetic-only"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^26.0.0",
        "eslint": "^10.5.0",
        "eslint-config-eslint": "^14.0.0",
        "globals": "^17.7.0"
    }
}
