{
    "compilerOptions": {
        "checkJs": true,
        "skipLibCheck": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ESNext",
        "maxNodeModuleJsDepth": 0,
        "strict": true,
        "noImplicitAny": false,
        "alwaysStrict": true,
        "noEmit": true,
        "types": ["node"]
    },
    "exclude": [
        "node_modules"
    ]
}
